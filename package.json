{
  "name": "foodzone",
  "version": "1.0.0",
  "description": "FoodZone - Modern Food Delivery Application",
  "main": "index.js",
  "private": true,
  "scripts": {
    "start": "concurrently \"cd app && npm run dev\" \"cd server && npm run server\"",
    "client": "cd app && npm run dev",
    "server": "cd server && npm run server",
    "build": "npm --prefix app run build && npm --prefix server run build",
    "install-all": "npm install && npm --prefix app install && npm --prefix server install"
  },
  "workspaces": [
    "app",
    "server"
  ],
  "keywords": [
    "food",
    "delivery",
    "react",
    "express",
    "typescript"
  ],
  "author": "Suraj Koli",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^8.0.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Surajk111000/FoodZone.git"
  },
  "bugs": {
    "url": "https://github.com/Surajk111000/FoodZone/issues"
  },
  "homepage": "https://github.com/Surajk111000/FoodZone#readme"
}
